# Radio-TTY Docker Compose environment
# Copy to .env — or just run: bash setup.sh (auto-generates it)
#
# Docker Compose reads this file automatically. Values here are overridden
# by variables already set in your shell environment.

# Your Linux user ID — used to locate the PulseAudio socket at /run/user/<UID>/pulse
# Run 'id -u' on the host to find yours. Default assumes UID 1000.
PULSE_UID=1000

# Whisper inference backend: cpu (default) | cuda | openvino
# Set to 'cuda' if the host has an NVIDIA GPU with the Container Toolkit installed.
COMPUTE_BACKEND=cpu
